{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SignalRank",
  "version": "0.1.0",
  "identifier": "app.signalrank.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:services",
    "beforeBuildCommand": "npm run build:web && npm run stage:sidecars",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../frontend/.next"
  },
  "app": {
    "windows": [
      {
        "title": "SignalRank",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../frontend/.next/standalone": "frontend/.next/standalone",
      "../../frontend/.next/static": "frontend/.next/standalone/.next/static",
      "../../frontend/public": "frontend/.next/standalone/public",
      "node-libs": "node-libs"
    },
    "externalBin": [
      "binaries/signalrank-backend",
      "binaries/signalrank-web"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
