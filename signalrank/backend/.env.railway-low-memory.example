# Railway low-memory profile
# Intended for small deployments: ~2-3 active users, split API + worker services.

# Required
DATABASE_URL=${{Postgres.DATABASE_URL}}
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>
OPENROUTER_API_KEY=sk-or-v1-...
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# DB pool: keep enough headroom for concurrent dashboard/jobs requests
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=3
DB_POOL_TIMEOUT=30

# Scraping/ranking caps
SCRAPER_MAX_RESULTS=1500
SCRAPER_HOURS_OLD=24
SCRAPER_DEFAULT_COUNTRY=India
LINKEDIN_MAX_QUERIES=0
RANKER_MAX_CANDIDATES=2000
RANKER_MAX_DESCRIPTION_CHARS=1200

# API service profile
RUN_API_WORKER=false
RUN_RESUME_WORKER=false
RUN_ARCHIVAL_WORKER=false
RUN_BOOT_SCAN=false
RUN_BOOT_EMBED=false

# Worker service profile
# Set these on the worker service, not the API service.
# RUN_API_WORKER=true
# RUN_RESUME_WORKER=true
# RUN_ARCHIVAL_WORKER=true
# RUN_BOOT_SCAN=false
# RUN_BOOT_EMBED=false
# RESUME_WORKER_CONCURRENCY=1
# ARCHIVAL_WORKER_CONCURRENCY=1
