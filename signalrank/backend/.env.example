# Required
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/signalrank
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>

# Optional: preferred runtime DB URL for Railway private networking.
# If set, the backend will use this instead of DATABASE_URL at runtime.
DATABASE_PRIVATE_URL=

# Optional: public DB URL for external/manual access only. Do not use for backend runtime.
DATABASE_PUBLIC_URL=

# Optional: alternate Railway PostgreSQL URL — enables DB switcher in the dev UI
DATABASE_URL_RAILWAY=
OPENROUTER_API_KEY=sk-or-v1-...

# Optional
HUNTER_API_KEY=
RAPIDAPI_KEY=
ALLOWED_ORIGINS=http://localhost:3000
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
SCRAPER_MAX_RESULTS=1500
SCRAPER_HOURS_OLD=24
SCRAPER_DEFAULT_COUNTRY=India
LINKEDIN_MAX_QUERIES=0
RANKER_MAX_CANDIDATES=2000
RANKER_MAX_DESCRIPTION_CHARS=1200
RUN_API_WORKER=true
RUN_RESUME_WORKER=true
RUN_ARCHIVAL_WORKER=true
RESUME_WORKER_CONCURRENCY=1
ARCHIVAL_WORKER_CONCURRENCY=1
RUN_BOOT_SCAN=false
RUN_BOOT_EMBED=false
